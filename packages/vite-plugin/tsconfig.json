{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "module": "esnext",
    "esModuleInterop": true,
    "target": "es2021",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
