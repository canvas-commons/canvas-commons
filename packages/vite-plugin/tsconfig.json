{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "module": "nodenext",
    "esModuleInterop": true,
    "target": "es2021",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "transform": "@canvas-commons/internal/transformers/markdown-literals.js"
      }
    ]
  },
  "include": ["src"]
}
