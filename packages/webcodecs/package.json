{
  "name": "@canvas-commons/webcodecs",
  "version": "0.4.0",
  "description": "A WebCodecs exporter for Canvas Commons",
  "type": "module",
  "main": "./lib/server/index.js",
  "types": "./lib/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/server/index.d.ts",
      "default": "./lib/server/index.js"
    },
    "./server": {
      "types": "./lib/server/index.d.ts",
      "default": "./lib/server/index.js"
    },
    "./client": {
      "types": "./lib/client/index.d.ts",
      "default": "./lib/client/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "author": "canvas-commons",
  "homepage": "https://canvascommons.io/",
  "bugs": "https://github.com/canvas-commons/canvas-commons/issues",
  "license": "MIT",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest run",
    "lint:pkg": "publint --strict && attw --pack . --profile esm-only --ignore-rules internal-resolution-error"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canvas-commons/canvas-commons.git",
    "directory": "packages/webcodecs"
  },
  "files": [
    "lib"
  ],
  "dependencies": {
    "@canvas-commons/core": "workspace:^",
    "@canvas-commons/vite-plugin": "workspace:^",
    "mediabunny": "^1.46.0"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
