{
  "name": "@canvas-commons/editor",
  "version": "0.2.0",
  "description": "A visual editor for Canvas Commons",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "author": "canvas-commons",
  "homepage": "https://canvascommons.io/",
  "bugs": "https://github.com/canvas-commons/canvas-commons/issues",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "type": "tsc -w",
    "showcase": "tsc && vite build -c vite.showcase.ts",
    "preview": "vite preview",
    "lint:pkg": "publint --strict && attw --pack . --profile esm-only --exclude-entrypoints ./style.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canvas-commons/canvas-commons.git",
    "directory": "packages/editor"
  },
  "files": [
    "dist",
    "tsconfig.plugin.json"
  ],
  "dependencies": {
    "@canvas-commons/core": "workspace:^",
    "@preact/signals": "catalog:",
    "highlight.js": "^11.9.0",
    "marked": "^15.0.0",
    "preact": "catalog:"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "catalog:",
    "clsx": "catalog:",
    "sass": "^1.69.5",
    "source-map-js": "^1.0.2",
    "vite": "catalog:",
    "vite-plugin-dts": "^4.5.4"
  }
}
