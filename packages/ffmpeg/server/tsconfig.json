{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../lib/server",
    "ignoreDeprecations": "6.0",
    "inlineSourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "module": "esnext",
    "target": "es2020",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["."]
}
