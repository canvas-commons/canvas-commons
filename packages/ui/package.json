{
  "name": "@canvas-commons/ui",
  "version": "0.1.0",
  "description": "A visual editor for Canvas Commons",
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "author": "canvas-commons",
  "homepage": "https://canvascommons.io/",
  "bugs": "https://github.com/canvas-commons/canvas-commons/issues",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "type": "tsc -w",
    "showcase": "tsc && vite build -c vite.showcase.ts",
    "preview": "vite preview",
    "lint:pkg": "publint --strict && attw --pack ."
  },
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/canvas-commons/canvas-commons.git",
    "directory": "packages/ui"
  },
  "files": [
    "dist",
    "tsconfig.plugin.json"
  ],
  "dependencies": {
    "@canvas-commons/core": "^0.1.0",
    "@preact/signals": "^1.2.1",
    "preact": "^10.19.2"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.7.0",
    "clsx": "^2.0.0",
    "highlight.js": "^11.9.0",
    "sass": "^1.69.5",
    "source-map-js": "^1.0.2",
    "vite-plugin-dts": "^4.0.3"
  }
}
